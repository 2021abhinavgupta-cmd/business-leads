# Copy this file to .env and fill in real values. Never commit .env.

# === AI API Keys (at least one required — fallback chain: Anthropic -> Gemini -> OpenAI) ===
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === AWS Credentials (SES email sending) ===
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-south-1
FROM_EMAIL=
# Public base URL of this deployment (e.g. https://myapp.up.railway.app), used
# to build a one-click unsubscribe link in the List-Unsubscribe header. Blank
# is fine (falls back to a mailto: unsubscribe link) but hurts deliverability
# with Gmail/Yahoo's bulk-sender rules.
APP_BASE_URL=

# === Google Sheets (legacy CRM) ===
GOOGLE_SHEETS_ID=
# Prefer this in production (Railway); local dev falls back to a credentials.json file in repo root.
GOOGLE_CREDENTIALS_JSON=

# === Scraper API Keys ===
GOOGLE_MAPS_API_KEY=
PAGESPEED_KEY=
APOLLO_API_KEY=

# === Instagram Credentials ===
IG_USERNAME=
IG_PASSWORD=

# === Limits & Settings ===
DAILY_EMAIL_LIMIT=100
# Options: maps, ecommerce, startups, b2b
LEAD_SOURCE=maps

# === Outreach ===
# Sender display name used to sign outreach emails (not read via config.py, read directly via os.getenv)
YOUR_NAME=

# === API Auth ===
# Required X-API-Key header value for all /api/* routes. If left blank, the API
# is unauthenticated (fine for local dev, NOT fine once deployed publicly).
# Set the same value in frontend/.env as VITE_API_KEY so the frontend can call the API.
API_KEY=

